{$DOMAIN:localhost} {
    # API backend
    handle /api/* {
        reverse_proxy knfapp-backend:8000
    }

    # Swagger UI
    handle /docs* {
        reverse_proxy knfapp-swagger:8080
    }

    # DbGate (admin only — consider restricting access)
    handle /dbgate* {
        reverse_proxy knfapp-dbgate:3000
    }

    # Default: serve static or return 404
    handle {
        respond "KNFAPP API Server" 200
    }

    log {
        output stdout
    }
}
