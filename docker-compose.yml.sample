version: "3.8"

# knfapp Docker Compose — copy to docker-compose.yml and fill in secrets
# See .env.sample for required environment variables

services:
  knfapp-backend:
    build: ./knfapp-backend
    container_name: knfapp-backend
    restart: unless-stopped
    read_only: true
    user: "1000:1000"
    ports:
      - "127.0.0.1:8000:8000"
    environment:
      - APP_DEBUG=${APP_DEBUG:-0}
      - SECRET_KEY=${SECRET_KEY}
      - JWT_SECRET=${JWT_SECRET}
      - DB_PATH=/data/knfapp.db
      - UPLOAD_DIR=/data/uploads
      - INVITATION_EXPIRY_HOURS=${INVITATION_EXPIRY_HOURS:-168}
    volumes:
      - ./_DATA/knfapp-backend:/data
      - /etc/localtime:/etc/localtime:ro
    tmpfs:
      - /tmp
    networks:
      - isolated-knfapp
      - external
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/health')"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

  knfapp-caddy:
    image: caddy:2-alpine
    container_name: knfapp-caddy
    restart: unless-stopped
    read_only: true
    user: "1000:1000"
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - ./_DATA/knfapp-caddy/data:/data
      - ./_DATA/knfapp-caddy/config:/config
      - /etc/localtime:/etc/localtime:ro
    networks:
      - isolated-knfapp
      - external
    depends_on:
      knfapp-backend:
        condition: service_healthy

  knfapp-swagger:
    image: swaggerapi/swagger-ui:latest
    container_name: knfapp-swagger
    restart: unless-stopped
    read_only: true
    environment:
      - SWAGGER_JSON=/app/swagger.yaml
    volumes:
      - ./knfapp-backend/swagger.yaml:/app/swagger.yaml:ro
      - /etc/localtime:/etc/localtime:ro
    networks:
      - isolated-knfapp
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:8080"]
      interval: 30s
      timeout: 5s
      retries: 3

  knfapp-dbgate:
    image: dbgate/dbgate:alpine
    container_name: knfapp-dbgate
    restart: unless-stopped
    environment:
      - CONNECTIONS=knfapp
      - LABEL_knfapp=KNFAPP SQLite
      - ENGINE_knfapp=sqlite@dbgate-plugin-sqlite
      - FILE_knfapp=/data/knfapp.db
    volumes:
      - ./_DATA/knfapp-backend:/data:ro
      - ./_DATA/knfapp-dbgate:/root/.dbgate
      - /etc/localtime:/etc/localtime:ro
    networks:
      - isolated-knfapp
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:3000"]
      interval: 30s
      timeout: 5s
      retries: 3

networks:
  isolated-knfapp:
    driver: bridge
    internal: true
    ipam:
      config:
        - subnet: 172.28.10.0/24
  external:
    driver: bridge
    ipam:
      config:
        - subnet: 172.28.11.0/24
