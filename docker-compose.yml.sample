services:

  knfapp-caddy:
    container_name: knfapp-caddy
    image: caddy:2-alpine
    read_only: true
    user: "1000:1000"
    ports:
      - "80:80"
    volumes:
      - ./endpoint/Caddyfile:/etc/caddy/Caddyfile:ro
    networks:
      - isolated-knfapp
      - external
    restart: unless-stopped


  knfapp-backend:
    container_name: knfapp-backend
    build: ./backend
    read_only: true
    user: "1000:1000"
    ports:
      - "127.0.0.1:8000:8000"
    environment:
      - APP_DEBUG=${APP_DEBUG:-0}
      - SECRET_KEY=${SECRET_KEY}
      - JWT_SECRET=${JWT_SECRET}
      - DB_PATH=/data/knfapp.db
      - UPLOAD_DIR=/data/uploads
      - INVITATION_EXPIRY_HOURS=${INVITATION_EXPIRY_HOURS:-168}
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - ./_DATA/knfapp-backend:/data
    tmpfs:
      - /tmp
    networks:
      - isolated-knfapp
      - external
    restart: unless-stopped



  knfapp-swagger:
    container_name: knfapp-swagger
    image: swaggerapi/swagger-ui:latest
    environment:
      - SWAGGER_JSON=/app/swagger.yaml
    volumes:
      - ./swagger/swagger.yaml:/app/swagger.yaml:ro
      - /etc/localtime:/etc/localtime:ro
    networks:
      - isolated-knfapp
    restart: unless-stopped
  

  knfapp-dbgate:
    container_name: knfapp-dbgate
    image: dbgate/dbgate:alpine
    environment:
      - CONNECTIONS=knfapp
      - LABEL_knfapp=KNFAPP SQLite
      - ENGINE_knfapp=sqlite@dbgate-plugin-sqlite
      - FILE_knfapp=/data/knfapp.db
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - ./_DATA/knfapp-backend:/data:ro
      - ./_DATA/knfapp-dbgate:/root/.dbgate

    networks:
      - isolated-knfapp
    restart: unless-stopped






networks:
  isolated-knfapp:
    driver: bridge
    internal: true
    ipam:
      config:
        - subnet: 172.28.10.0/24
  external:
    driver: bridge
    ipam:
      config:
        - subnet: 172.28.11.0/24
