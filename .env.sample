# knfapp environment variables — copy to .env and fill in

# Backend
APP_DEBUG=0
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET=change-me-to-another-random-string
INVITATION_EXPIRY_HOURS=168
# UPLOAD_DIR=/data/uploads  # Image upload directory (Docker: /data/uploads, local: auto-created under backend/data/uploads)

# Domain (for Caddy)
DOMAIN=knfapp.example.com
